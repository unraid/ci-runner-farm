<script>
/* Poll only when the Fleet tab is actually on screen. document.hidden covers a
   backgrounded browser tab; offsetParent covers the inactive dynamix sub-tab
   (all tabs share one document, so document.hidden stays false on Settings/Image
   while Fleet's pollers would otherwise keep hitting docker on the NAS). */
function crfFleetActive(){ const b=document.getElementById('crf-bays-body'); return !document.hidden && !!b && b.offsetParent!==null; }
let crfUserLog=false;
function crfLog(o){ crfUserLog=true; document.getElementById('crf-log').innerHTML = crfColorize(o.log||JSON.stringify(o)); }
/* Until the user triggers an action, the Fleet log shows live farm activity
   (autoscale daemon log) instead of sitting on a placeholder. */
function crfFarmLog(){
  if(crfUserLog||!crfFleetActive()) return;
  crfPost({action:'farm-log'}).then(d=>{
    if(crfUserLog||!d.log) return;
    const el=document.getElementById('crf-log');
    el.innerHTML=crfColorize(d.log); el.scrollTop=el.scrollHeight;
  }).catch(()=>{});
}
crfFarmLog(); setInterval(crfFarmLog,10000);
/* Lightweight theme-following toast for action feedback. */
const CRF_TOAST_MSG={start:'Fleet started',stop:'Fleet stopped',restart:'Fleet restarted',validate:'Validation finished'};
function crfDoAction(a){ crfPost({action:a}).then(o=>{crfLog(o); crfRefresh(); if(o.ok!==false) crfToast(CRF_TOAST_MSG[a]||a); else crfToast((CRF_TOAST_MSG[a]||a)+' failed'+(o.error?': '+o.error:'')); }).catch(e=>{ crfToast((CRF_TOAST_MSG[a]||a)+' failed'); console.error('ci-runner-farm '+a+':',e); }); }
function crfAction(a){
  /* Stop/Restart kill whatever the runners are building — confirm with the
     live impact when any runner is mid-job (sweetalert ships with the webgui). */
  if((a==='stop'||a==='restart')&&window.swal){
    const busy=((window.CRF_LAST||{}).runners||[]).filter(r=>r.state==='running'&&r.phase==='busy');
    if(busy.length){
      const lines=busy.map(r=>r.name+(r.job?' — '+r.job:'')).join('\n');
      swal({title:(a==='stop'?'Stop':'Restart')+' the fleet?',
        text:busy.length+' runner'+(busy.length>1?'s are':' is')+' mid-job:\n'+lines+'\n\nTheir jobs will fail and re-queue.',
        type:'warning',showCancelButton:true,confirmButtonText:a==='stop'?'Stop fleet':'Restart fleet',cancelButtonText:'Cancel'},
        ok=>{ if(ok) crfDoAction(a); });
      return;
    }
  }
  crfDoAction(a);
}
function crfScale(){ const n=document.getElementById('crf-n').value; crfPost({action:'scale',n}).then(o=>{crfLog(o); crfRefresh(); if(o.ok!==false) crfToast('Scaled to '+n); else crfToast('Scale failed'+(o.error?': '+o.error:''));}).catch(e=>{ crfToast('Scale failed'); console.error('ci-runner-farm scale:',e); }); }

function crfElapsed(iso){
  const t=Date.parse(iso); if(isNaN(t)) return null;
  const m=Math.floor((Date.now()-t)/60000);
  return {m, txt: m<1?'<1m': m<60? m+'m' : Math.floor(m/60)+'h'+String(m%60).padStart(2,'0')};
}
function crfBar(pct){
  const p=Math.max(0,Math.min(100,Math.round(pct)));
  const cls=p>90?' crf-hot':p>60?' crf-mid':'';
  return '<span class="crf-ubar'+cls+'"><span style="width:'+p+'%"></span></span>';
}
/* The per-poll VOLATILE cells — the elapsed timer and the CPU/mem bars, which tick
   every 5s for a busy runner. Factored out so the full row builder and crfRefresh's
   in-place fast-path render them identically from ONE source of truth (no drift). */
function crfVolatile(r){
  const running=r.state==='running';
  let elapsedHtml='';
  if(running&&r.phase==='busy'&&r.job_started){
    const e=crfElapsed(r.job_started);
    if(e) elapsedHtml=' <span class="crf-elapsed'+(e.m>=120?' crf-el-hot':e.m>=30?' crf-el-warn':'')+'" title="running for '+e.txt+'">'+e.txt+'</span>';
  }
  const cpuMax=(r.cpus&&r.cpus>0)?r.cpus*100:100;
  const cpuKnown=running&&r.cpu_pct>=0, memKnown=running&&r.mem_used_mib>=0&&r.mem_gb;
  const cpuPct=cpuKnown?(100*r.cpu_pct/cpuMax):0;
  const memPct=memKnown?100*r.mem_used_mib/(r.mem_gb*1024):0;
  const cpuTxt=cpuKnown?Math.round(r.cpu_pct)+'%':(running?'…':'&ndash;');
  const memTxt=memKnown?((r.mem_used_mib>=1024?( (r.mem_used_mib/1024).toFixed(1)+'g'):(r.mem_used_mib+'m'))+'/'+r.mem_gb+'g'):(running?'…':'&ndash;');
  return {elapsedHtml,cpuPct,cpuTxt,memPct,memTxt};
}
function crfRefresh(){
  // In-flight guard: never stack a new status poll while the previous is still
  // outstanding, so a slow backend can't spiral into overlapping polls.
  if(!crfFleetActive() || window.__crfBusyStatus) return;
  window.__crfBusyStatus=true;
  crfPost({action:'status-json'}).then(d=>{
    window.CRF_LAST=d;
    const warn=document.getElementById('crf-warn');
    if(warn){ if(d.warning){ warn.textContent='⚠ '+d.warning; warn.style.display='block'; } else { warn.textContent=''; warn.style.display='none'; } }
    const sec=document.getElementById('crf-sec');
    if(sec){ if(d.security){ sec.textContent='🔒 '+d.security; sec.style.display='block'; } else { sec.textContent=''; sec.style.display='none'; } }
    // Runners still on a previous baked config after a settings change — the reconciler
    // recycles them onto the new config as they go idle (busy jobs finish first).
    const mig=document.getElementById('crf-migrate');
    if(mig){ if(d.stale>0){ mig.textContent='⟳ '+d.stale+' runner'+(d.stale>1?'s':'')+' updating to the new configuration — recycling as they go idle, so running jobs finish first.'; mig.style.display='block'; } else { mig.textContent=''; mig.style.display='none'; } }
    const rs=d.runners||[];
    const up=rs.filter(r=>r.state==='running').length;
    const busy=rs.filter(r=>r.state==='running'&&r.phase==='busy').length;
    const idle=rs.filter(r=>r.state==='running'&&r.phase==='idle').length;
    const put=(id,v)=>{const el=document.getElementById(id); if(el) el.textContent=v;};
    put('crf-s-up',up); put('crf-s-busy',busy); put('crf-s-idle',idle);
    put('crf-s-as',d.autoscale||'off'); put('crf-s-iu',d.image_autoupdate||'off');
    const tb=document.getElementById('crf-bays-body'); if(!tb) return;
    // Capture the open drawer's LIVE scroll before the rebuild below destroys the
    // node, so crfDrawerMount can restore the user's position (not snap to tail).
    const odr=window.CRF_DRAWER&&document.querySelector('.crf-bay-drawer[data-for="'+window.CRF_DRAWER+'"]');
    if(odr){ window.CRF_DRAWER_PINNED=crfDrawerPinned(odr); window.CRF_DRAWER_SCROLL=odr.scrollTop; }
    if(!rs.length){
      tb.innerHTML='<div class="crf-empty"><span class="crf-ball"></span>'+
        '<div><strong>No managed runners</strong><div class="crf-muted">Configured for '+crfEsc(d.configured||0)+' — start the fleet to register them with GitHub.</div></div>'+
        '<uui-button size="sm"'+(crfDark()?' class="dark"':'')+' onclick="crfAction(\'start\')">Start the fleet</uui-button></div>';
      return;
    }
    const dark=crfDark()?' class="dark"':'';
    // In-place fast-path: rebuilding crf-bays-body's innerHTML every 5s recreates every
    // <uui-badge> web component and drops keyboard focus / text selection on each poll.
    // Most polls are steady-state — same runners and jobs, only CPU/mem/elapsed ticking —
    // so when the STRUCTURE is unchanged we refresh just those volatile cells in place and
    // leave the rows (and the open drawer sibling) alive. Any structural change (runner
    // added/removed, phase flip, new job, theme or drawer toggle) changes the signature
    // and falls through to the full rebuild below. busy-with-job_started is in the
    // signature so the .crf-elapsed span's presence always matches what the row was built
    // with — the in-place branch can then update it without ever needing to create it.
    const sig=JSON.stringify([dark,window.CRF_DRAWER,rs.map(r=>[r.name,r.state,r.phase,r.job,r.repo,r.run_id,r.pr,r.branch,r.cpus,r.mem_gb,r.state==='running'&&r.phase==='busy'&&!!r.job_started])]);
    if(tb.__crfSig===sig && tb.querySelector('.crf-bay[data-name]')){
      rs.forEach(r=>{
        const row=tb.querySelector('.crf-bay[data-name="'+(window.CSS&&CSS.escape?CSS.escape(r.name):r.name)+'"]'); if(!row) return;
        const v=crfVolatile(r);
        const u=row.querySelectorAll('.crf-usage');
        if(u[0]) u[0].innerHTML=crfBar(v.cpuPct)+'<span class="crf-uval">'+v.cpuTxt+'</span>';
        if(u[1]) u[1].innerHTML=crfBar(v.memPct)+'<span class="crf-uval">'+v.memTxt+'</span>';
        const el=row.querySelector('.crf-elapsed');
        if(el&&r.job_started){ const e=crfElapsed(r.job_started); if(e){ el.textContent=e.txt; el.title='running for '+e.txt; el.className='crf-elapsed'+(e.m>=120?' crf-el-hot':e.m>=30?' crf-el-warn':''); } }
      });
      crfDrawerMount();
      return;
    }
    tb.__crfSig=sig;
    tb.innerHTML=rs.map(r=>{
      const running=r.state==='running';
      const ph=running?r.phase:'exited';
      const ball=running?('crf-ball-'+r.phase):'crf-ball';
      const bvar=ph==='busy'?'orange':ph==='idle'?'green':ph==='error'?'red':'gray';
      let jobHtml;
      const v=crfVolatile(r);
      if(running&&r.phase==='busy'){
        const repoShort=r.repo?crfEsc(String(r.repo).split('/').pop()):'';
        const runOk=/^\d+$/.test(r.run_id||'');
        const jobTxt=crfEsc(r.job||'\u2014');
        const core=(repoShort?'<span class="crf-repo" title="'+crfEsc(r.repo)+'">'+repoShort+'</span> \u00b7 ':'')+jobTxt;
        jobHtml=(runOk&&r.repo)?'<a href="https://github.com/'+crfEsc(r.repo)+'/actions/runs/'+r.run_id+'" target="_blank" rel="noopener" title="open run">'+core+'</a>':core;
        if(/^\d+$/.test(r.pr||'')&&r.repo) jobHtml+='<a class="crf-ref" href="https://github.com/'+crfEsc(r.repo)+'/pull/'+r.pr+'" target="_blank" rel="noopener">#'+r.pr+'</a>';
        else if(r.branch) jobHtml+='<span class="crf-ref">'+crfEsc(r.branch)+'</span>';
        jobHtml+=v.elapsedHtml;
      } else {
        jobHtml=crfEsc(running?'waiting for jobs':r.state);
      }
      const jobCls=running&&r.phase==='busy'&&r.job?'crf-job':'crf-job crf-muted';
      return '<div class="crf-bay" data-name="'+crfEsc(r.name)+'" tabindex="0" role="button" aria-expanded="'+(window.CRF_DRAWER===r.name?'true':'false')+'" aria-label="Runner '+crfEsc(r.name)+', toggle log">'+
        '<span class="crf-ball '+ball+'"></span>'+
        '<span class="crf-name">'+crfEsc(r.name)+'</span>'+
        '<span class="crf-phase"><uui-badge variant="'+bvar+'" size="xs"'+dark+'>'+crfEsc(ph)+'</uui-badge></span>'+
        '<span class="'+jobCls+'" title="'+crfEsc(r.job||'')+'">'+jobHtml+'</span>'+
        '<span class="crf-usage">'+crfBar(v.cpuPct)+'<span class="crf-uval">'+v.cpuTxt+'</span></span>'+
        '<span class="crf-usage">'+crfBar(v.memPct)+'<span class="crf-uval">'+v.memTxt+'</span></span>'+
        '<span class="crf-recycle" tabindex="0" role="button" aria-label="Recycle '+crfEsc(r.name)+'" title="Recycle this runner">&#10227;</span>'+
      '</div>';
    }).join('');
    crfDrawerMount();
  }).catch(e=>{
    // A rejected status poll (network down, or a 403 from a CSRF token that expired
    // on a reboot/array restart) must NOT look like an empty fleet — surface it in
    // the warning banner and keep the last-rendered bays in place. Cleared by the
    // next successful poll (the d.warning handling above overwrites/hides it).
    const warn=document.getElementById('crf-warn');
    if(warn){ warn.textContent='⚠ '+(String((e&&e.message)||'').indexOf('session expired')>=0?'Session expired — reload the page to reconnect.':'Lost connection to the server — retrying…'); warn.style.display='block'; }
    console.error('ci-runner-farm status:',e);
  }).finally(()=>{ window.__crfBusyStatus=false; });
}
crfRefresh(); setInterval(crfRefresh,5000);
function crfQueued(){
  if(!crfFleetActive()) return;
  crfPost({action:'queued-json'}).then(d=>{
    const el=document.getElementById('crf-s-q'); if(!el) return;
    const q=(typeof d.queued==='number'&&d.queued>=0)?d.queued:null;
    el.textContent=q===null?'\u2013':q;
    el.classList.toggle('crf-c-busy',!!q);
  }).catch(()=>{});
}
crfQueued(); setInterval(crfQueued,30000);
function crfBytes(b){ if(typeof b!=='number'||b<0) return '\u2013'; const u=['B','K','M','G','T']; let i=0,v=b; while(v>=1024&&i<u.length-1){v/=1024;i++;} return (i===0?v:(v>=10?Math.round(v):v.toFixed(1)))+u[i]; }
function crfCacheUsage(){
  if(!crfFleetActive()) return;
  crfPost({action:'cache-usage'}).then(d=>{
    window.CRF_CACHE=d;
    const el=document.getElementById('crf-s-cache'); if(el) el.textContent=crfBytes(d.total);
    const clr=document.getElementById('crf-cache-clear'); if(clr) clr.title=(d.pkg>0?crfBytes(d.pkg)+' reclaimable':'');
  }).catch(()=>{});
}
crfCacheUsage(); setInterval(crfCacheUsage,30000);
function crfStats(){
  if(!crfFleetActive()) return;
  crfPost({action:'stats-json'}).then(d=>{
    const put=(id,v)=>{const e=document.getElementById(id); if(e) e.textContent=v;};
    const dash='\u2013';
    if(!(typeof d.total==='number'&&d.total>=0)){  // no token / API down — signal, don't show a confident 0
      put('crf-rs-ok',dash); put('crf-rs-fail',dash); put('crf-rs-cancel',dash); put('crf-rs-rate',dash);
      put('crf-rs-total',dash+' total across your repos'); return;
    }
    const settled=(d.ok||0)+(d.fail||0)+(d.cancel||0);
    put('crf-rs-ok',d.ok??dash); put('crf-rs-fail',d.fail??dash); put('crf-rs-cancel',d.cancel??dash);
    put('crf-rs-rate', settled>0 ? Math.round(100*(d.ok||0)/settled)+'%' : dash);
    put('crf-rs-total', d.total+' total across your repos');
  }).catch(()=>{});
}
crfStats(); setInterval(crfStats,60000);
function crfCacheClear(){
  const pkg=(window.CRF_CACHE&&window.CRF_CACHE.pkg)||0;
  const doIt=()=>crfPost({action:'cache-clear'})
    .then(o=>{ crfToast(o.ok?'Package caches cleared':('Clear failed'+(o.error?': '+o.error:''))); crfCacheUsage(); })
    .catch(e=>{ crfToast('Clear failed'); console.error('ci-runner-farm cache-clear:',e); });
  const msg='Removes '+crfBytes(pkg)+' of warm cargo, npm, yarn, pnpm, sccache, and Playwright caches. Running jobs keep working (a cache miss at worst); workspaces and Docker data are left intact.';
  if(window.swal){ swal({title:'Clear package caches?',text:msg,type:'warning',showCancelButton:true,confirmButtonText:'Clear caches',cancelButtonText:'Cancel'},ok=>{ if(ok) doIt(); }); }
  else if(confirm('Clear package caches? '+msg)) doIt();
}
function crfRecycle(name){
  const r=((window.CRF_LAST||{}).runners||[]).find(x=>x.name===name)||{};
  const go=()=>crfPost({action:'recycle',name})
    .then(o=>{ crfToast(o.ok?('Recycled '+name):('Recycle failed'+(o.error?': '+o.error:''))); crfRefresh(); })
    .catch(e=>{ crfToast('Recycle failed'); console.error('ci-runner-farm recycle:',e); });
  if(r.state==='running'&&r.phase==='busy'&&window.swal){
    swal({title:'Recycle '+name+'?',text:'It is mid-job'+(r.job?': '+r.job:'')+'.\nThe job will fail and re-queue.',type:'warning',showCancelButton:true,confirmButtonText:'Recycle',cancelButtonText:'Cancel'},ok=>{ if(ok) go(); });
  } else go();
}
/* Click a bay to open a live log drawer for that runner. It persists across the
   5s re-render: crfRefresh rebuilds crf-bays-body's innerHTML (destroying this
   node), so we cache the last log + scroll position and restore them on re-mount
   rather than flashing "loading…" and yanking the view back to the tail. The live
   scroll is captured in crfRefresh just before the rebuild (see CRF_DRAWER_SCROLL). */
window.CRF_DRAWER=null; window.CRF_DRAWER_HTML=''; window.CRF_DRAWER_SCROLL=0; window.CRF_DRAWER_PINNED=true;
function crfDrawerPinned(el){ return el.scrollHeight-el.scrollTop-el.clientHeight < 24; }
function crfDrawerFill(name){
  crfPost({action:'runner-log',name}).then(d=>{
    const el=document.querySelector('.crf-bay-drawer[data-for="'+name+'"]');
    if(el&&window.CRF_DRAWER===name){
      const pinned=crfDrawerPinned(el), prev=el.scrollTop;
      window.CRF_DRAWER_HTML=crfColorize(d.log||'(no output)');
      el.innerHTML=window.CRF_DRAWER_HTML;
      // Stick to the tail only if the user was already there; otherwise keep their
      // place so reading a mid-log error isn't interrupted on the next poll.
      el.scrollTop = pinned ? el.scrollHeight : prev;
      window.CRF_DRAWER_SCROLL=el.scrollTop; window.CRF_DRAWER_PINNED=pinned;
    }
  }).catch(()=>{});
}
function crfDrawerMount(){
  document.querySelectorAll('.crf-bay-drawer').forEach(e=>{ if(e.dataset.for!==window.CRF_DRAWER) e.remove(); });
  if(!window.CRF_DRAWER) return;
  if(document.querySelector('.crf-bay-drawer[data-for="'+window.CRF_DRAWER+'"]')){
    crfDrawerFill(window.CRF_DRAWER);
    return;
  }
  const row=document.querySelector('#crf-bays-body .crf-bay[data-name="'+window.CRF_DRAWER+'"]');
  if(!row) return;
  const d=document.createElement('div'); d.className='crf-bay-drawer'; d.dataset.for=window.CRF_DRAWER;
  // Re-seed with the last log so a 5s re-render doesn't flash "loading…"; only the
  // very first open (no cached HTML) shows the placeholder.
  d.innerHTML=window.CRF_DRAWER_HTML||'<span class="crf-muted">loading log...</span>';
  row.after(d);
  if(window.CRF_DRAWER_HTML) d.scrollTop = window.CRF_DRAWER_PINNED ? d.scrollHeight : window.CRF_DRAWER_SCROLL;
  crfDrawerFill(window.CRF_DRAWER);
}
function crfToggleDrawer(name){
  const opening = window.CRF_DRAWER!==name;
  window.CRF_DRAWER = opening ? name : null;
  window.CRF_DRAWER_HTML=''; window.CRF_DRAWER_SCROLL=0; window.CRF_DRAWER_PINNED=true; // fresh cache per open
  const row=document.querySelector('#crf-bays-body .crf-bay[data-name="'+name+'"]');
  if(row) row.setAttribute('aria-expanded', opening?'true':'false');
  crfDrawerMount();
}
document.getElementById('crf-bays-body').addEventListener('click',e=>{
  const rc=e.target.closest('.crf-recycle');
  if(rc){ const b=rc.closest('.crf-bay[data-name]'); if(b) crfRecycle(b.dataset.name); return; }
  if(e.target.closest('a,uui-button,.crf-bay-drawer')) return;
  const row=e.target.closest('.crf-bay[data-name]'); if(!row) return;
  crfToggleDrawer(row.dataset.name);
});
document.getElementById('crf-bays-body').addEventListener('keydown',e=>{
  if(e.key!=='Enter'&&e.key!==' ') return;
  const rc=e.target.closest('.crf-recycle');
  if(rc){ e.preventDefault(); const b=rc.closest('.crf-bay[data-name]'); if(b) crfRecycle(b.dataset.name); return; }
  const row=e.target.closest('.crf-bay[data-name]');
  if(row&&e.target===row){ e.preventDefault(); crfToggleDrawer(row.dataset.name); }
});
/* No separate drawer-refresh timer: crfRefresh() rebuilds the bays and calls
   crfDrawerMount() every cycle (and is itself gated by crfFleetActive()), which
   re-fills the open drawer. A second interval here double-fetched runner-log and
   ignored the sub-tab guard, so it kept hitting docker on the NAS off-tab. */
/* Pause all polling while the tab is hidden (each poller costs a docker
   stats + per-runner exec on the NAS); refresh immediately on return. */
document.addEventListener('visibilitychange',()=>{
  if(document.hidden) return;
  crfRefresh(); crfQueued(); crfFarmLog(); crfCacheUsage(); crfStats();
  if(window.CRF_DRAWER) crfDrawerFill(window.CRF_DRAWER);
});
/* Switching to the Fleet dynamix sub-tab doesn't fire visibilitychange; refresh
   on its tab button so the paused pollers catch up immediately, not in 5s. */
document.getElementById('tab1') && document.getElementById('tab1').addEventListener('click',()=>{
  setTimeout(()=>{ crfRefresh(); crfQueued(); crfFarmLog(); crfCacheUsage(); crfStats(); },60);
});
</script>
