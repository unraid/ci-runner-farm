<?php
/* Runner image builder tab: image status band, ACE-powered Dockerfile editor
   (core dynamix ships ace with a dockerfile mode), and the build pipeline.
   The crf* JS core and .crf-* styles live on the Fleet tab (same document). */
$crf_plugin = 'ci-runner-farm';
$crf_df     = "/boot/config/plugins/$crf_plugin/Dockerfile";
$crf_df_saved = is_file($crf_df);
if (!$crf_df_saved) $crf_df = "/usr/local/emhttp/plugins/$crf_plugin/default.Dockerfile";
$crf_dockerfile = is_file($crf_df) ? file_get_contents($crf_df) : '';
?>
<script src="<?autov('/plugins/dynamix/javascript/ace/ace.js')?>"></script>

<div class="crfi-band" id="crfi-band">
  <div class="crfs-tok-status">
    <span class="crf-ball" id="crfi-ball"></span>
    <span class="crfs-tok-text">
      <strong id="crfi-title">Checking runner image...</strong>
      <span class="crfs-tok-sub" id="crfi-sub">ci-runner-farm-runner:latest</span>
    </span>
  </div>
  <div class="crfi-chips" id="crfi-chips"></div>
</div>

<div class="crfi-editor">
  <div class="crfi-editor-head">
    <span class="crfi-path"><span class="crf-ball crfi-dot" id="crfi-dirty" title="Unsaved changes"></span><code id="crfi-df-path"><?=htmlspecialchars($crf_df, ENT_QUOTES)?></code></span>
    <span class="crfi-editor-tools">
      <span class="crfi-status"><span class="crf-ball" id="crfi-build-ball" style="display:none"></span><span id="crf-build-status" class="crf-muted"></span></span>
      <uui-button variant="ghost" size="xs" onclick="crfiResetDf()">Reset to shipped default</uui-button>
      <uui-button variant="secondary" size="xs" onclick="crfSaveDf()">Save Dockerfile</uui-button>
      <uui-button size="xs" onclick="crfBuild()">Save + Build</uui-button>
    </span>
  </div>
  <div id="crfi-ace"></div>
  <textarea id="crf-dockerfile" style="display:none"><?=htmlspecialchars($crf_dockerfile, ENT_QUOTES)?></textarea>
</div>

<div class="crf-console">
  <div class="crf-console-head">
    <span>Build log</span>
    <uui-button variant="outline" size="xs" onclick="crfCopyBuildLog(this)">Copy</uui-button>
  </div>
  <div id="crf-build-log" class="crf-console-body"><span class="crf-muted">Build output appears here. Set Image source to Built-in on the Settings tab and restart the fleet to use a new build.</span></div>
</div>

<style>
  .crfi-band{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;border:1px solid var(--border-color);border-radius:6px;background:var(--shade-bg-color,transparent);padding:10px 14px;margin:6px 0 8px}
  .crfi-chips{display:flex;gap:8px;flex-wrap:wrap}
  .crfi-chip{font-size:11px;color:var(--alt-text-color);border:1px solid var(--border-color);border-radius:10px;padding:2px 10px;white-space:nowrap}
  .crfi-chip b{color:var(--text-color);font-weight:normal}
  .crfi-editor{border:1px solid var(--border-color);border-radius:6px;overflow:hidden;margin:0 0 8px}
  .crfi-editor-head{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:3px 6px 3px 12px;min-height:30px;box-sizing:border-box;background:var(--table-header-background-color)}
  .crfi-path{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--alt-text-color)}
  .crfi-path code{font-family:bitstream,monospace;font-size:11px}
  .crfi-dot{width:8px;height:8px;visibility:hidden}
  .crfi-dot.on{visibility:visible;background:var(--crf-busy)}
  .crfi-editor-tools{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .crfi-editor-tools input[type=button]{margin:0;font-size:11px}
  .crfi-editor-tools uui-button:not(:defined),.crfi-editor-tools uui-brand-button:not(:defined){cursor:pointer;border:1px solid var(--border-color);border-radius:6px;padding:3px 10px;font-size:11px;color:var(--text-color)}
  .crfi-status{display:flex;align-items:center;gap:6px;font-size:11px}
  #crfi-ace{height:340px;font-size:12px;font-family:bitstream,monospace}
</style>

<script>
function crfiRelTime(iso){
  const t=Date.parse(iso); if(isNaN(t)) return '';
  const m=Math.round((Date.now()-t)/60000);
  if(m<1) return 'just now'; if(m<60) return m+'m ago';
  const h=Math.round(m/60); if(h<48) return h+'h ago';
  return Math.round(h/24)+'d ago';
}
function crfiInfo(){
  crfPost({action:'image-info'}).then(d=>{
    const ball=document.getElementById('crfi-ball'), title=document.getElementById('crfi-title'),
          sub=document.getElementById('crfi-sub'), chips=document.getElementById('crfi-chips');
    if(!d.exists){
      ball.className='crf-ball crf-ball-error';
      title.textContent='Runner image not built yet';
      sub.textContent=(d.image||'ci-runner-farm-runner:latest')+' — save the Dockerfile and press Save + Build.';
      chips.innerHTML='';
      return;
    }
    ball.className='crf-ball crf-ball-idle';
    title.textContent='Runner image built '+crfiRelTime(d.created);
    sub.textContent=d.image+' · '+d.id;
    const chip=(l,v)=>'<span class="crfi-chip">'+l+' <b>'+crfEsc(v)+'</b></span>';
    chips.innerHTML=
      chip('base',d.base||'?')+
      chip('size',(d.size_mb||0)+' MB')+
      chip('runners on it',d.in_use+'')+
      (d.source==='remote'?chip('image source','Remote — builds here are unused until Settings switches to Built-in'):'');
  }).catch(()=>{});
}
crfiInfo();

let crfiAce=null, crfiSaved='';
(function(){
  const ta=document.getElementById('crf-dockerfile');
  if(!window.ace){ ta.style.display='block'; ta.rows=18; return; }
  ace.config.set('basePath','/plugins/dynamix/javascript/ace');
  crfiAce=ace.edit('crfi-ace');
  const dark=/Theme--(black|gray)\b/.test(document.documentElement.className);
  crfiAce.setTheme('ace/theme/'+(dark?'tomorrow_night':'tomorrow'));
  crfiAce.session.setMode('ace/mode/dockerfile');
  crfiAce.setOptions({fontFamily:'bitstream,monospace',fontSize:'12px',showPrintMargin:false,useWorker:false,tabSize:2});
  crfiSaved=ta.value; crfiAce.setValue(ta.value,-1);
  crfiAce.session.on('change',()=>{
    ta.value=crfiAce.getValue();
    document.getElementById('crfi-dirty').classList.toggle('on',ta.value!==crfiSaved);
  });
})();
function crfiResetDf(){
  crfPost({action:'get-default-dockerfile'}).then(d=>{
    if(!d.dockerfile) return;
    if(crfiAce) crfiAce.setValue(d.dockerfile,-1); else document.getElementById('crf-dockerfile').value=d.dockerfile;
    document.getElementById('crf-build-status').textContent='shipped default loaded — not saved yet';
  });
}
function crfiBuildState(state,msg){
  const b=document.getElementById('crfi-build-ball');
  b.style.display=state?'inline-block':'none';
  b.className='crf-ball '+(state==='busy'?'crf-ball-busy':state==='ok'?'crf-ball-idle':state==='err'?'crf-ball-error':'');
  document.getElementById('crf-build-status').textContent=msg||'';
}
function crfSaveDf(cb){ crfPost({action:'save-dockerfile',dockerfile:document.getElementById('crf-dockerfile').value}).then(o=>{
  if(o.ok){ crfiSaved=document.getElementById('crf-dockerfile').value; document.getElementById('crfi-dirty').classList.remove('on');
    document.getElementById('crfi-df-path').textContent='/boot/config/plugins/ci-runner-farm/Dockerfile'; }
  crfiBuildState(o.ok?'ok':'err', o.ok?'saved':('error: '+(o.error||'')));
  if(typeof cb==='function'&&o.ok) cb(); }); }
function crfBuild(){ crfiBuildState('busy','saving + building...'); crfSaveDf(function(){ crfPost({action:'build-image'}).then(()=>crfPollBuild()); }); }
function crfPollBuild(){ crfPost({action:'build-log'}).then(d=>{ const el=document.getElementById('crf-build-log'); el.innerHTML=crfColorize(d.log||''); el.scrollTop=el.scrollHeight;
  if(d.running){ crfiBuildState('busy','building...'); setTimeout(crfPollBuild,2000); }
  else { const ok=!/error|failed/i.test((d.log||'').split('\n').slice(-6).join('\n'));
    crfiBuildState(ok?'ok':'err', ok?'build finished — restart the fleet to use it':'build failed — see log'); crfiInfo(); } }); }
function crfCopyBuildLog(btn){
  const t=document.getElementById('crf-build-log').textContent||'';
  navigator.clipboard.writeText(t).then(()=>{ const o=btn.textContent; btn.textContent='Copied'; setTimeout(()=>btn.textContent=o,1500); }).catch(()=>{});
}
</script>
