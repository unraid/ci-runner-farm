Menu="RunnerFarm:2"
Title="Runner image"
Tag="cube"
---
<?php
/* Runner image builder tab. Reads the saved Dockerfile (falls back to the
   packaged default) — the crf* JS core lives on the Fleet tab (same document). */
$crf_plugin = 'ci-runner-farm';
$crf_df     = "/boot/config/plugins/$crf_plugin/Dockerfile";
if (!is_file($crf_df)) $crf_df = "/usr/local/emhttp/plugins/$crf_plugin/default.Dockerfile";
$crf_dockerfile = is_file($crf_df) ? file_get_contents($crf_df) : '';
?>
<div class="crf-builder-wrap">
<p><strong>Runner image builder</strong> &mdash; edit the Dockerfile for the built-in runner image (add apt packages, tools, browsers), Save, then Build. It's tagged <code>ci-runner-farm-runner:latest</code>; set <em>Image source</em> to <strong>Built-in</strong> on the Settings tab and restart the fleet to use a new build.</p>
<textarea id="crf-dockerfile" rows="18" spellcheck="false"><?=htmlspecialchars($crf_dockerfile, ENT_QUOTES)?></textarea>
<p>
  <input type="button" value="Save Dockerfile" onclick="crfSaveDf()">
  <input type="button" value="Build image" onclick="crfBuild()">
  <span id="crf-build-status" class="crf-muted"></span>
</p>
<div class="crf-console">
  <div class="crf-console-head">
    <span>Build log</span>
    <input type="button" value="Copy" onclick="crfCopyBuildLog(this)">
  </div>
  <div id="crf-build-log" class="crf-console-body"><span class="crf-muted">Build output appears here.</span></div>
</div>
</div>

<script>
function crfSaveDf(cb){ crfPost({action:'save-dockerfile',dockerfile:document.getElementById('crf-dockerfile').value}).then(o=>{ document.getElementById('crf-build-status').textContent = o.ok?'saved':('error: '+(o.error||'')); if(typeof cb==='function') cb(); }); }
function crfBuild(){ document.getElementById('crf-build-status').textContent='saving + building...'; crfSaveDf(function(){ crfPost({action:'build-image'}).then(()=>crfPollBuild()); }); }
function crfPollBuild(){ crfPost({action:'build-log'}).then(d=>{ const el=document.getElementById('crf-build-log'); el.textContent=d.log||''; el.scrollTop=el.scrollHeight; if(d.running){ document.getElementById('crf-build-status').textContent='building...'; setTimeout(crfPollBuild,2000);} else { document.getElementById('crf-build-status').textContent='build finished — restart the fleet to use it'; } }); }
function crfCopyBuildLog(btn){
  const t=document.getElementById('crf-build-log').textContent||'';
  navigator.clipboard.writeText(t).then(()=>{ btn.value='Copied'; setTimeout(()=>btn.value='Copy',1500); }).catch(()=>{});
}
</script>
