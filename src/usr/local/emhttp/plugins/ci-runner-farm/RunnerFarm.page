<script>
const CRF_CSRF = "<?=$csrf?>";
const CRF_URL  = "/plugins/ci-runner-farm/include/exec.php";
function crfPost(p){
  p.csrf_token = CRF_CSRF;
  return fetch(CRF_URL,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:Object.entries(p).map(([k,v])=>encodeURIComponent(k)+'='+encodeURIComponent(v)).join('&')}).then(r=>r.json());
}
function crfLog(o){ document.getElementById('crf-log').textContent = (o.log||JSON.stringify(o)); }
function crfAction(a){ crfPost({action:a}).then(o=>{crfLog(o); crfRefresh();}); }
function crfScale(){ crfPost({action:'scale',n:document.getElementById('crf-n').value}).then(o=>{crfLog(o); crfRefresh();}); }
function crfSetToken(){ const t=document.getElementById('crf-token').value; if(!t)return;
  crfPost({action:'set-token',token:t}).then(o=>{document.getElementById('crf-tok').innerHTML=o.ok?'configured &#10004;':'error';document.getElementById('crf-token').value='';}); }
function crfSetRegistryToken(){ const t=document.getElementById('crf-registry-token').value; if(!t)return;
  crfPost({action:'set-registry-token',token:t}).then(o=>{document.getElementById('crf-regtok').innerHTML=o.ok?'configured &#10004;':'error';document.getElementById('crf-registry-token').value='';}); }
// show/hide the remote-only fields (Remote image + registry server/username/token)
// based on the Image source select. Targets each field's <dd>+<dt> (Unraid
// markdown forms are MarkdownExtra definition lists). Hide-only (never disable):
// disabled inputs aren't submitted, which would drop the values on Apply;
// display:none inputs still submit, so values persist when switching modes. If
// the DOM ever differs, the fields simply stay visible — no harm.
function crfImgSrc(){
  const sel=document.getElementsByName('IMAGE_SOURCE')[0];
  const remote=sel&&sel.value==='remote';
  const disp=remote?'':'none';
  ['IMAGE','REGISTRY_SERVER','REGISTRY_USERNAME'].forEach(n=>{
    const el=document.getElementsByName(n)[0]; if(!el) return;
    const dd=el.closest('dd'); const row=dd||el.closest('tr');
    if(row) row.style.display=disp;
    if(dd&&dd.previousElementSibling) dd.previousElementSibling.style.display=disp;
  });
  const auth=document.getElementById('crf-remote-auth'); if(auth) auth.style.display=disp;
}
crfImgSrc();
function crfRefresh(){
  crfPost({action:'status-json'}).then(d=>{
    const warn=document.getElementById('crf-warn');
    if(warn){ if(d.warning){ warn.textContent='⚠ '+d.warning; warn.style.display='block'; } else { warn.textContent=''; warn.style.display='none'; } }
    const sec=document.getElementById('crf-sec');
    if(sec){ if(d.security){ sec.textContent='🔒 '+d.security; sec.style.display='block'; } else { sec.textContent=''; sec.style.display='none'; } }
    const meta=document.getElementById('crf-meta');
    if(meta){ meta.textContent='Autoscale: '+(d.autoscale||'off')+'  ·  Image auto-update: '+(d.image_autoupdate||'off'); }
    const tb=document.querySelector('#crf-table tbody'); tb.innerHTML='';
    if(!d.runners||!d.runners.length){ tb.innerHTML='<tr><td colspan="5">no managed runners (configured: '+(d.configured||0)+')</td></tr>'; return; }
    d.runners.forEach(r=>{ const cls=r.state!=='running'?'crf-exited':('crf-'+r.phase);
      tb.innerHTML+='<tr><td>'+r.name+'</td><td>'+r.state+'</td><td><span class="crf-pill '+cls+'">'+r.phase+'</span></td><td>'+(r.cpus?r.cpus+'c':'max')+'</td><td>'+r.mem_gb+'g</td></tr>'; });
  }).catch(()=>{});
}
crfRefresh(); setInterval(crfRefresh,5000);
function crfSaveDf(cb){ crfPost({action:'save-dockerfile',dockerfile:document.getElementById('crf-dockerfile').value}).then(o=>{ document.getElementById('crf-build-status').textContent = o.ok?'saved':('error: '+(o.error||'')); if(typeof cb==='function') cb(); }); }
function crfBuild(){ document.getElementById('crf-build-status').textContent='saving + building...'; crfSaveDf(function(){ crfPost({action:'build-image'}).then(()=>crfPollBuild()); }); }
function crfPollBuild(){ crfPost({action:'build-log'}).then(d=>{ document.getElementById('crf-log').textContent=d.log||''; if(d.running){ document.getElementById('crf-build-status').textContent='building...'; setTimeout(crfPollBuild,2000);} else { document.getElementById('crf-build-status').textContent='build finished — restart the fleet to use it'; } }); }
// Native Unraid folder picker on the Cache root path field
if (window.jQuery) jQuery(function($){ if ($.fn.fileTreeAttach) $("#CACHE_ROOT").fileTreeAttach(); });
</script>
